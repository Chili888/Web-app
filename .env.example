# Telegram Bot API token from BotFather. Backend only; never expose to browser code.
TELEGRAM_BOT_TOKEN=
# Random setWebhook secret using only A-Z, a-z, 0-9, underscore, and hyphen.
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=TJ_ice_CS_bot
# Comma-separated private-chat administrators. Non-admin users are always customers.
TELEGRAM_ADMIN_IDS=7141080131
TELEGRAM_MAIN_CHANNEL=@TJ_NO1_ice
TELEGRAM_DISCUSSION_GROUP=@TJ_ice_Group
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=900
# Deprecated compatibility alias for TELEGRAM_ADMIN_IDS; leave empty for new deployments.
TELEGRAM_AGENT_ALLOWLIST=

# Existing Supabase project URL. Public URL only; backend currently connects through PostgreSQL.
SUPABASE_URL=
# Public publishable/anon key used by backend admin APIs to validate Supabase Auth sessions.
SUPABASE_ANON_KEY=
# Reserved for future backend Supabase APIs. Leave empty until a feature actually requires it.
SUPABASE_SERVICE_ROLE_KEY=
# PostgreSQL owner/BYPASSRLS connection string used by API, Worker, and migration CLI.
DATABASE_URL=
# Production Supabase Session Pooler URL. Production Compose maps this to DATABASE_URL.
SUPABASE_DATABASE_URL=
# Supabase production connections use verify-full. Base64-encode the project's Server root certificate.
DATABASE_SSL_MODE=verify-full
DATABASE_SSL_CA_BASE64=
APP_BASE_URL=http://localhost:3000
# Exact public Mini App origin allowed to call browser-facing APIs. Do not include a path.
STOREFRONT_ORIGIN=https://chili888.github.io
APP_TIMEZONE=Asia/Shanghai

JOIN_VERIFY_ENABLED=true
JOIN_VERIFY_TIMEOUT_SECONDS=600
JOIN_VERIFY_TIMEOUT_ACTION=kick
AUTO_REPLY_ENABLED=true

LOG_LEVEL=info
PORT=3000
WORKER_POLL_INTERVAL_MS=500
WORKER_MAX_ATTEMPTS=8
WORKER_RETRY_BASE_MS=1000

# Used only by the optional local PostgreSQL service in docker-compose.yml.
POSTGRES_DB=telegram_support
POSTGRES_USER=telegram_support
POSTGRES_PASSWORD=
